{
  "type": "object",
  "title": "Extractor Configuration",
  "required": ["authentication", "sync_options"],
  "properties": {
    "authentication": {
      "type": "object",
      "title": "Authentication",
      "required": ["api_user", "#api_password"],
      "properties": {
        "api_user": {
          "type": "string",
          "title": "API Username",
          "propertyOrder": 1
        },
        "#api_password": {
          "type": "string",
          "title": "API Password",
          "propertyOrder": 2
        }
      }
    },
    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "required": ["datasets"],
      "properties": {
        "datasets": {
          "type": "array",
          "title": "Datasets",
          "items": {
            "type": "string",
            "enum": ["general", "sales", "food"]
          },
          "description": "List of datasets to fetch. Supported values: 'general', and 'sales'.",
          "propertyOrder": 3
        },
        "location_ids": {
          "type": "array",
          "title": "Location IDs",
          "items": {
            "type": "number"
          },
          "description": "List of location IDs for which data should be fetched.",
          "propertyOrder": 4
        },
        "date_from": {
          "type": "string",
          "format": "date",
          "title": "Start Date",
          "description": "Optional start date for data synchronization (default 2020-01-01).",
          "propertyOrder": 5
        },
        "date_to": {
          "type": "string",
          "format": "date",
          "title": "End Date",
          "description": "Optional end date for data synchronization (default today()).",
          "propertyOrder": 6
        },
        "generate_date_range": {
          "type": "boolean",
          "title": "Generate Date Range",
          "description": "Generate date range between 'date_from' and 'date_to'. Default: 'false'.",
          "propertyOrder": 7
        }
      }
    },
    "debug": {
      "type": "boolean",
      "title": "Debug Mode",
      "default": false,
      "propertyOrder": 8
    }
  }
}