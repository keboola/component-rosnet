{
  "type": "object",
  "title": "Extractor Configuration",
  "required": ["authentication", "sync_options"],
  "properties": {
    "authentication": {
      "type": "object",
      "title": "Authentication",
      "required": ["api_user", "#api_password"],
      "properties": {
        "api_user": {
          "type": "string",
          "title": "API Username",
          "propertyOrder": 1
        },
        "#api_password": {
          "type": "string",
          "title": "API Password",
          "propertyOrder": 2
        }
      }
    },
    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "required": ["datasets"],
      "properties": {
        "datasets": {
          "type": "array",
          "title": "Datasets",
          "items": {
            "type": "string",
            "enum": ["general", "food"]
          },
          "description": "List of datasets to fetch. Only 'general' and 'food' are supported in this version.",
          "propertyOrder": 3
        }
      }
    },
    "debug": {
      "type": "boolean",
      "title": "Debug Mode",
      "default": false,
      "propertyOrder": 4
    }
  }
}